rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public catalog — anyone can read; authenticated users can write (admin).
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;

      // Product reviews — public read; signed-in users can post their own.
      // Reviews are immutable once created.
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // App configuration (e.g. USD rate, homepage content) — public read,
    // authenticated write (admin-only in production, lock to specific UIDs).
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Per-user data: a signed-in user can touch their own document tree.
    // Any authenticated user can read (for admin features like user tracking).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /{sub=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Orders: a user can create and read their own orders.
    // Authenticated users can list all orders (for admin).
    match /orders/{orderId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null;
      allow delete: if false;
    }

    // Notifications: authenticated admins can read/write.
    match /notifications/{notifId} {
      allow read, write: if request.auth != null;
    }

    // Audit logs: authenticated users can create; authenticated can read.
    match /audit_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // AI conversations: written by the Cloud Function (admin SDK bypasses rules).
    // Authenticated admins can read; clients cannot write directly.
    match /ai_conversations/{convId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Support conversations: shared between the customer and admin agents.
    // Any authenticated user can read/write (admin UI is access-gated in-app,
    // matching the existing posture for orders and ai_conversations).
    match /support_conversations/{convId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Quotations: customers can create; admins can read/update/delete.
    match /quotations/{quoteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // API keys: managed exclusively via admin-gated Cloud Functions
    // (the Admin SDK bypasses these rules). No direct client access —
    // this keeps key hashes and metadata unreadable from the client.
    match /apiKeys/{keyId} {
      allow read, write: if false;
    }

    // API request logs: written by the API function (Admin SDK) and read via
    // the admin-gated getApiActivity callable. No direct client access.
    match /apiLogs/{logId} {
      allow read, write: if false;
    }

    // Repair tickets: customers can create their own; admins can read/update all.
    match /repair_tickets/{ticketId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }
  }
}
