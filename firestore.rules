rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public catalog — anyone can read; authenticated users can write (admin).
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;

      // Product reviews — public read; signed-in users can post their own.
      // Reviews are immutable once created.
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // App configuration (e.g. USD rate, homepage content) — public read,
    // authenticated write (admin-only in production, lock to specific UIDs).
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Per-user data: a signed-in user can touch their own document tree.
    // Any authenticated user can read (for admin features like user tracking).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /{sub=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Orders: a user can create and read their own orders.
    // Authenticated users can list all orders (for admin).
    match /orders/{orderId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null;
      allow delete: if false;
    }
  }
}
